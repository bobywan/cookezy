# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=boby-boilerplate

# ──────────────────────────────────────────────
# Database (example)
# ──────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ──────────────────────────────────────────────
# Auth (example)
# ──────────────────────────────────────────────
# AUTH_SECRET=your-secret-key

# ──────────────────────────────────────────────
# Proposition de recette (Resend)
# ──────────────────────────────────────────────
# Clé API Resend : https://resend.com → API Keys
RESEND_API_KEY=re_...
# Email de destination pour les propositions (le tien)
CONTACT_EMAIL=toi@example.com
# Expéditeur (domaine vérifié sur Resend, ou laisser onboarding@resend.dev en dev)
RESEND_FROM_EMAIL=onboarding@resend.dev

# ──────────────────────────────────────────────
# External APIs (example)
# ──────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
